default_platform(:ios)

platform :ios do
  desc "Build and export IPA"
  lane :release do
    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      output_directory: "./build/ipa",
      output_name: "AIProductScanner.ipa",
      export_options: {
        provisioningProfiles: {
          "com.aiproductscanner.app" => ENV["PROVISIONING_PROFILE_SPECIFIER"]
        }
      }
    )
  end
end
