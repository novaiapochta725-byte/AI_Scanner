{
  "name": "ai-product-scanner",
  "version": "1.0.0",
  "description": "AI Product Scanner — identify products from images using Gemini API",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "start:desktop": "electron .",
    "cap:init": "npx cap add ios",
    "cap:sync": "npm run build && npx cap sync ios",
    "cap:open": "npx cap open ios",
    "ios:setup": "bash scripts/setup-ios.sh",
    "ios:setup:ci": "bash scripts/setup-ios-ci.sh",
    "ios:build": "bash scripts/build-ios.sh",
    "ios:ipa": "bash scripts/build-ipa-unsigned.sh"
  },
  "keywords": [
    "capacitor",
    "ios",
    "gemini",
    "product-scanner",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@capacitor/browser": "^7.0.0",
    "@capacitor/camera": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/keyboard": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "electron": "^35.7.5",
    "vite": "^6.2.0"
  }
}
